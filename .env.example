# ============================================================================
# CONFIGURACIÓN DE MICROSERVICIOS - Sistema de Préstamos de Dispositivos
# ============================================================================

# ============== API GATEWAY (PUERTO 3000) ==============
GATEWAY_PORT=3000

# ============== LOAN SERVICE (PUERTO 3001) ==============
LOAN_SERVICE_HOST=localhost
LOAN_SERVICE_PORT=3001
LOAN_SERVICE_RPC_PORT=3011

# ============== DEVICE SERVICE (PUERTO 3002) ==============
DEVICE_SERVICE_HOST=localhost
DEVICE_SERVICE_PORT=3002

# ============== BASES DE DATOS ==============
# Cada servicio usa su propio archivo de base de datos SQLite
# SQLite: usar ruta ABSOLUTA. Las rutas relativas se resuelven desde prisma/ y suelen fallar.
# Ejemplo Windows: DATABASE_URL="file:D:/ruta/al/proyecto/backend/loan-service/prisma/dev.db"

# ============== ENTORNO ==============
NODE_ENV=development
